datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

enum AdminRole {
  ROOT_SUPERADMIN
  ADMIN
}

model SuperAdmin {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String
  passwordHash String
  
  role         AdminRole @default(ADMIN)
  status       String    @default("active") // "active" | "suspended"
  
  appointedById String?
  appointedBy   SuperAdmin?  @relation("AdminAppointee", fields: [appointedById], references: [id])
  appointees    SuperAdmin[] @relation("AdminAppointee")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    SuperAdminAuditLog[]
}

model LguTenant {
  id           String    @id @default(uuid())
  code         String    @unique // e.g., "taytay", "sanjuan"
  name         String
  level        String    // "province" | "city" | "municipality" | "barangay"
  apiUrl       String?
  status       String    @default("active") // "active" | "suspended" | "maintenance"
  licenseKey   String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OnboardingRequest {
  id            String    @id @default(uuid())
  orgCode       String    @unique
  orgName       String
  level         String    // "province" | "city" | "municipality" | "barangay"
  sysAdminEmail String
  status        String    @default("pending") // "pending" | "provisioning" | "completed" | "failed"
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SuperAdminAuditLog {
  id         String     @id @default(uuid())
  actorId    String
  actor      SuperAdmin @relation(fields: [actorId], references: [id])
  action     String     // e.g., "onboard_lgu", "suspend_lgu", "generate_license"
  details    String?    // Detailed description of the action
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())
}
